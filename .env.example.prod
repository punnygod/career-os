# Database Configuration
# Obtain this full connection string from your Supabase Dashboard -> Settings -> Database
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_connection_string_here

# Backend Configuration
BACKEND_SECRET_KEY=your_very_long_secure_random_string_here
BACKEND_PROD_URL=https://api.yourdomain.com # The public URL of your backend (used by frontend to call API)

# Frontend Configuration
FRONTEND_PROD_URL=https://yourdomain.com # The public URL of your frontend (used by backend for CORS)
